# Copie para .env na raiz ou defina no Railway (Variables).
# VITE_* entram no bundle no momento do build — marque-as como disponíveis no build no Railway.

# --- Frontend (build) ---
VITE_CLERK_PUBLISHABLE_KEY=
# Opcional: só se API estiver noutro domínio (deploy unificado no Railway não precisa)
# VITE_API_URL=

# --- Backend (runtime) ---
PORT=3000
NODE_ENV=production

# Postgres (preferir uma connection string completa)
DATABASE_URL=
# Alternativa: DB_HOST, DB_PORT, DB_USERNAME, DB_PASSWORD, DB_DATABASE
# DB_SSL=true

# CORS: lista separada por vírgulas (mesmo host em deploy unificado costuma dispensar)
# CORS_ORIGINS=https://teu-dominio.up.railway.app

# Gemini
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_MAX_OUTPUT_TOKENS=4096
